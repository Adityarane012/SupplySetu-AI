# SupplySetu AI — Environment Variables
# Copy this to .env and fill in your actual values

# ─── Supabase ────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJYOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJYOUR_SERVICE_ROLE_KEY

# ─── Backend URL ─────────────────────────────────────────
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ─── Ollama (Local LLM — already running) ────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Use llama3.2:3b (fast) or gemma2:2b (also good)
OLLAMA_MODEL=llama3.2:3b

# ─── Whisper (Local STT — no API key needed) ─────────────
# Options: tiny, base, small, medium  (base is best balance)
WHISPER_MODEL_SIZE=base

# ─── Graphify ────────────────────────────────────────────
GRAPHIFY_OLLAMA_NUM_CTX=8192
