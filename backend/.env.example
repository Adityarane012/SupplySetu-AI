# ==========================================
# SupplySetu AI Backend Environment Template
# ==========================================

# 1. Cloud Fallback Toggle (For Judges)
# Set to false to bypass local models and use Groq API for instant inference
USE_LOCAL_MODEL=true
GROQ_API_KEY=your_groq_api_key_here

# 2. Local Model Settings
OLLAMA_BASE_URL=http://localhost:11434
WHISPER_MODEL_SIZE=small

# 3. Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# 4. Twilio WhatsApp Webhook (Optional)
# Required only if you are testing the live WhatsApp sandbox integration
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
